# ─────────────────────────────────────────────────────
# Neeman's Listing Health Monitor — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────

# ScrapingBee API key
# Sign up at https://app.scrapingbee.com and copy your key from the dashboard.
SCRAPINGBEE_API_KEY=your_scrapingbee_api_key_here

# Absolute (or relative) path to the Google service-account JSON credential file.
# See README.md for instructions on creating this file.
GOOGLE_SHEETS_CREDENTIALS_PATH=/path/to/service-account.json

# The Google Sheet ID — the long alphanumeric string in the spreadsheet URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here
